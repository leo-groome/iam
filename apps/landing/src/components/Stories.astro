---
import { stories } from "../data/stories";

const featured = stories[0];
const rest = stories.slice(1);
---

<section id="historias" class="relative py-24 md:py-32 bg-[color:var(--color-surface)]">
  <div class="container-x">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <span class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] font-medium">Historias reales</span>
        <h2 class="font-display text-4xl md:text-5xl mt-4 leading-tight">
          Cada vida tiene<br/>
          <span class="italic text-[color:var(--color-primary)]">una historia que contar.</span>
        </h2>
      </div>
      <p class="md:max-w-sm text-[color:var(--color-text-muted)]">
        Crónicas de madres, familias y voluntarios que dijeron sí. Entrá en cada historia
        para leerla completa.
      </p>
    </div>

    <a
      href={`/historias/${featured.slug}`}
      class="group block relative overflow-hidden rounded-3xl bg-[color:var(--color-bg)] border border-[color:var(--color-border)] mb-6 hover:shadow-2xl hover:shadow-[color:var(--color-primary)]/10 transition-all"
    >
      <div class="grid lg:grid-cols-2 gap-0">
        <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden">
          <img
            src={featured.cover}
            alt={featured.name}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <span class="absolute top-5 left-5 px-3 py-1 rounded-full bg-white/95 backdrop-blur text-[10px] uppercase tracking-widest text-[color:var(--color-primary)] font-semibold">
            Destacada · {featured.category}
          </span>
        </div>

        <div class="p-8 md:p-12 flex flex-col justify-center">
          <div class="flex items-center gap-3 text-xs text-[color:var(--color-text-muted)] mb-4">
            <span>{featured.date}</span>
            <span class="w-1 h-1 rounded-full bg-[color:var(--color-text-muted)]/40"></span>
            <span>{featured.readingTime}</span>
          </div>
          <h3 class="font-display text-3xl md:text-4xl leading-tight text-[color:var(--color-text)] group-hover:text-[color:var(--color-primary)] transition-colors">
            {featured.headline}
          </h3>
          <p class="mt-5 text-[color:var(--color-text-muted)] leading-relaxed">
            {featured.excerpt}
          </p>

          <div class="mt-8 flex items-center justify-end">
            <span class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-primary)]">
              Leer historia
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
        </div>
      </div>
    </a>

    <div class="grid md:grid-cols-3 gap-6">
      {rest.map((s) => (
        <a
          href={`/historias/${s.slug}`}
          class="group flex flex-col bg-[color:var(--color-bg)] rounded-3xl border border-[color:var(--color-border)] overflow-hidden hover:border-[color:var(--color-primary)]/30 hover:shadow-xl hover:shadow-[color:var(--color-primary)]/5 transition-all"
        >
          <div class="relative aspect-[5/4] overflow-hidden">
            <img
              src={s.cover}
              alt={s.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 px-2.5 py-1 rounded-full bg-white/95 backdrop-blur text-[10px] uppercase tracking-widest text-[color:var(--color-primary)] font-semibold">
              {s.category}
            </span>
          </div>

          <div class="p-6 flex-1 flex flex-col">
            <div class="flex items-center gap-3 text-xs text-[color:var(--color-text-muted)] mb-3">
              <span>{s.date}</span>
              <span class="w-1 h-1 rounded-full bg-[color:var(--color-text-muted)]/40"></span>
              <span>{s.readingTime}</span>
            </div>

            <h3 class="font-display text-xl leading-snug text-[color:var(--color-text)] group-hover:text-[color:var(--color-primary)] transition-colors">
              {s.headline}
            </h3>

            <p class="mt-3 text-sm text-[color:var(--color-text-muted)] leading-relaxed line-clamp-3">
              {s.excerpt}
            </p>

            <div class="mt-6 pt-5 border-t border-[color:var(--color-border)] flex items-center justify-end">
              <span class="inline-flex items-center gap-1 text-xs font-medium text-[color:var(--color-primary)]">
                Leer
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <p class="mt-12 text-center text-sm text-[color:var(--color-text-muted)]">
      ¿Tenés una historia que contar? <a href="#contacto" class="text-[color:var(--color-primary)] underline underline-offset-4">Compartila →</a>
    </p>
  </div>
</section>
