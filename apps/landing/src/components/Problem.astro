---
---

<section id="proyecto" class="relative py-28 md:py-40 bg-[color:var(--color-bg)] text-[color:var(--color-text)] overflow-hidden">
  <!-- Diagonal logo in corner -->
  <img
    src="/MISIONERAS_LOGO.svg"
    alt=""
    aria-hidden="true"
    class="absolute -bottom-32 -right-32 md:-bottom-40 md:-right-40 w-[480px] md:w-[640px] opacity-[0.12] rotate-[35deg] pointer-events-none"
  />

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <!-- Content -->
      <div class="lg:col-span-6 order-2 lg:order-1">
        <p class="text-xs uppercase tracking-[0.3em] text-[color:var(--color-accent)] font-medium mb-6">
          ¿Te interesa?
        </p>
        <h2 class="font-display text-6xl md:text-8xl lg:text-[9rem] leading-[0.9] text-[color:var(--color-text)]">
          I.A.M
        </h2>
        <p class="mt-6 font-display text-3xl md:text-4xl lg:text-5xl leading-[1] text-[color:var(--color-primary)] max-w-lg">
          Un lugar para <em>aprender sobre la vida.</em>
        </p>
        <p class="mt-6 text-lg text-[color:var(--color-text-muted)] leading-relaxed max-w-lg">
          Un espacio para concientizar sobre la vida y aprenderla desde su inicio.
          Encontrarte con otros, hacer preguntas, descubrir respuestas — y dejar
          que algo se mueva por dentro.
        </p>

        <ul class="mt-8 flex flex-wrap gap-2">
          <li class="px-4 py-2 rounded-full bg-[color:var(--color-primary)]/8 text-[color:var(--color-primary)] text-sm font-medium">Aprender</li>
          <li class="px-4 py-2 rounded-full bg-[color:var(--color-primary)]/8 text-[color:var(--color-primary)] text-sm font-medium">Compartir</li>
          <li class="px-4 py-2 rounded-full bg-[color:var(--color-primary)]/8 text-[color:var(--color-primary)] text-sm font-medium">Acompañar</li>
          <li class="px-4 py-2 rounded-full bg-[color:var(--color-accent)]/10 text-[color:var(--color-accent)] text-sm font-medium">Defender la vida</li>
        </ul>

        <a
          href="#ayudar"
          class="mt-10 inline-flex items-center gap-2 px-7 py-4 rounded-full bg-[color:var(--color-primary)] text-white font-semibold hover:bg-[color:var(--color-accent)] transition-colors shadow-xl"
        >
          Quiero aprender
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Image collage -->
      <div class="lg:col-span-6 order-1 lg:order-2 relative">
        <div class="grid grid-cols-2 gap-3 md:gap-4">
          <div class="space-y-3 md:space-y-4 pt-8 md:pt-12">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden">
              <img
                src="/images/img-09.webp"
                alt="Niña descubriendo la vida"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img
                src="/images/img-10.webp"
                alt="Misioneros compartiendo"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
          <div class="space-y-3 md:space-y-4">
            <div class="aspect-square rounded-2xl overflow-hidden">
              <img
                src="/images/img-24.webp"
                alt="Niño con modelo prenatal"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="aspect-[3/4] rounded-2xl overflow-hidden">
              <img
                src="/images/img-29.webp"
                alt="Niño abrazando la vida"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
