---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { stories } from "../../data/stories";

export function getStaticPaths() {
  return stories.map((s) => ({ params: { slug: s.slug }, props: { story: s } }));
}

const { story } = Astro.props;
const related = stories.filter((s) => s.slug !== story.slug).slice(0, 3);
---

<BaseLayout title={`${story.headline} — IAM`} description={story.excerpt}>
  <article class="pt-28 md:pt-36 pb-20">
    <div class="container-x">
      <a href="/#historias" class="inline-flex items-center gap-2 text-sm text-[color:var(--color-text-muted)] hover:text-[color:var(--color-primary)] transition-colors mb-10">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver a historias
      </a>

      <header class="max-w-3xl">
        <span class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] font-medium">{story.category}</span>
        <h1 class="font-display text-4xl md:text-6xl mt-4 leading-[1.05] text-[color:var(--color-text)]">
          {story.headline}
        </h1>

        <div class="mt-8 flex items-center gap-3 text-sm text-[color:var(--color-text-muted)]">
          <span>{story.date}</span>
          <span class="w-1 h-1 rounded-full bg-[color:var(--color-text-muted)]/40"></span>
          <span>{story.readingTime}</span>
        </div>
      </header>
    </div>

    <div class="container-x mt-12">
      <div class="relative w-full aspect-[16/9] md:aspect-[21/9] rounded-3xl overflow-hidden">
        <img src={story.cover} alt={story.name} class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="container-x mt-14">
      <div class="max-w-2xl mx-auto">
        <p class="font-display text-2xl md:text-3xl text-[color:var(--color-text)] leading-snug border-l-4 border-[color:var(--color-accent)] pl-6 italic">
          {story.excerpt}
        </p>

        <div class="mt-10 space-y-6 text-lg leading-[1.8] text-[color:var(--color-text)]">
          {story.body.map((p) => <p>{p}</p>)}
        </div>

        <div class="mt-14 p-8 rounded-3xl bg-[color:var(--color-primary)] text-white">
          <p class="font-display text-2xl leading-snug">
            ¿Necesitás acompañamiento como {story.name}?
          </p>
          <p class="mt-3 text-white/85">
            Estamos para escucharte sin juzgar. Tu historia importa.
          </p>
          <a href="/#contacto" class="mt-6 inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white text-[color:var(--color-primary)] font-medium hover:bg-white/90 transition-colors">
            Hablar con IAM
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </article>

  <section class="pb-24 md:pb-32">
    <div class="container-x">
      <div class="border-t border-[color:var(--color-border)] pt-14">
        <div class="flex items-end justify-between mb-10">
          <h2 class="font-display text-3xl md:text-4xl">Otras historias</h2>
          <a href="/#historias" class="text-sm text-[color:var(--color-primary)] font-medium hidden sm:inline-flex items-center gap-1">
            Ver todas
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {related.map((s) => (
            <a href={`/historias/${s.slug}`} class="group block">
              <div class="aspect-[5/4] rounded-2xl overflow-hidden mb-4">
                <img src={s.cover} alt={s.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              </div>
              <span class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] font-medium">{s.category}</span>
              <h3 class="font-display text-xl mt-2 leading-snug group-hover:text-[color:var(--color-primary)] transition-colors">{s.headline}</h3>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
