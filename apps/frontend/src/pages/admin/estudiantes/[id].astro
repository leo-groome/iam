---
import AdminLayout from "@/layouts/AdminLayout.astro";

export function getStaticPaths() {
  return ['1','2','3','4','5'].map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const estudiante = { id, nombre: 'Alex Hernández', email: 'alex@correo.com', edad: 28, registro: '15 mayo 2026', ultimo: 'Hoy 10:32' };
const cursos = [
  { id: 'acompanamiento-social', title: 'Acompañamiento social y defensa de la vida', progreso: 47, intentos: 1, calificacion: 80 },
  { id: 'comunicacion-empatica', title: 'Comunicación empática', progreso: 100, intentos: 1, calificacion: 95 },
];
---
<AdminLayout title={estudiante.nombre} section="estudiantes">
  <a href="/admin/estudiantes" class="text-sm text-[var(--color-text-muted)] mb-3 inline-block">← Estudiantes</a>

  <div class="card p-6 mb-6 flex items-center gap-4">
    <div class="w-16 h-16 rounded-full bg-[var(--color-primary)] text-white grid place-items-center text-2xl font-bold">
      {estudiante.nombre[0]}
    </div>
    <div class="flex-1">
      <h1 class="text-2xl font-bold">{estudiante.nombre}</h1>
      <p class="text-[var(--color-text-muted)]">{estudiante.email}</p>
      <p class="text-sm text-[var(--color-text-muted)] mt-1">Edad: {estudiante.edad} · Registro: {estudiante.registro} · Último acceso: {estudiante.ultimo}</p>
    </div>
  </div>

  <h2 class="text-lg font-semibold mb-3">Cursos inscritos</h2>
  <div class="space-y-3">
    {cursos.map(c => (
      <div class="card p-5">
        <div class="flex items-start justify-between gap-3 mb-3">
          <h3 class="font-semibold">{c.title}</h3>
          <span class="chip">{c.progreso}%</span>
        </div>
        <div class="h-2 bg-[var(--color-primary-soft)] rounded-full overflow-hidden mb-3">
          <div class="h-full bg-[var(--color-primary)]" style={`width: ${c.progreso}%`}></div>
        </div>
        <div class="grid grid-cols-2 gap-3 text-sm text-[var(--color-text-muted)]">
          <p>Intentos en exámenes: <strong class="text-[var(--color-text)]">{c.intentos}</strong></p>
          <p>Promedio: <strong class="text-[var(--color-text)]">{c.calificacion}/100</strong></p>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
