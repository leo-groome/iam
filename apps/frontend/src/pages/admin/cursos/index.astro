---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { cursos } from "@/lib/mock";
---
<AdminLayout title="Cursos" section="cursos">
  <header class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold">Cursos</h1>
      <p class="text-[var(--color-text-muted)]">Gestiona el contenido de la plataforma.</p>
    </div>
    <a href="/admin/cursos/nuevo" class="btn btn-primary">+ Crear curso</a>
  </header>

  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-[var(--color-app-bg)] text-left text-[var(--color-text-muted)]">
        <tr>
          <th class="px-4 py-3 font-medium">Título</th>
          <th class="px-4 py-3 font-medium">Módulos</th>
          <th class="px-4 py-3 font-medium">Edad</th>
          <th class="px-4 py-3 font-medium">Estado</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[var(--color-border)]">
        {cursos.map(c => (
          <tr class="hover:bg-[var(--color-app-bg)]">
            <td class="px-4 py-3 font-medium">{c.title}</td>
            <td class="px-4 py-3">{c.modulos.length}</td>
            <td class="px-4 py-3 text-[var(--color-text-muted)]">{c.ageMin}–{c.ageMax}</td>
            <td class="px-4 py-3"><span class="chip">Publicado</span></td>
            <td class="px-4 py-3 text-right">
              <a href={`/admin/cursos/${c.id}`} class="text-[var(--color-primary)] font-medium">Editar</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
