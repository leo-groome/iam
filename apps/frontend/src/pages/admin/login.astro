---
import PublicLayout from "@/layouts/PublicLayout.astro";
---
<PublicLayout title="Admin · Iniciar sesión">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="card p-8 w-full max-w-md">
      <div class="text-center mb-6">
        <img src="/MISIONERAS_LOGO.svg" alt="Misioneras" class="h-14 w-auto mx-auto" />
        <h1 class="text-xl font-bold mt-3">Panel administrador</h1>
        <p class="text-[var(--color-text-muted)] text-sm">Solo personal autorizado.</p>
      </div>
      <form action="/admin" class="space-y-3">
        <div>
          <label class="label" for="email">Correo</label>
          <input id="email" type="email" class="input" required />
        </div>
        <div>
          <label class="label" for="password">Contraseña</label>
          <input id="password" type="password" class="input" required />
        </div>
        <button class="btn btn-primary btn-block">Entrar</button>
      </form>
    </div>
  </div>
</PublicLayout>
