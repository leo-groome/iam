---
import PublicLayout from "@/layouts/PublicLayout.astro";
---
<PublicLayout title="Crear cuenta">
  <div class="min-h-screen flex items-center justify-center px-4 py-10">
    <div class="card p-8 w-full max-w-md">
      <a href="/" class="text-sm text-[var(--color-text-muted)] mb-4 inline-block">← Volver</a>
      <h1 class="text-2xl font-bold">Crea tu cuenta</h1>
      <p class="text-[var(--color-text-muted)] text-sm mt-1 mb-6">Es gratis y solo te toma un minuto.</p>

      <form action="/catalogo" class="space-y-4">
        <div>
          <label class="label" for="nombre">Nombre completo</label>
          <input id="nombre" type="text" class="input" placeholder="Tu nombre" required minlength="3" maxlength="80" />
        </div>
        <div>
          <label class="label" for="email">Correo</label>
          <input id="email" type="email" class="input" placeholder="tu@correo.com" required maxlength="120" />
        </div>
        <div>
          <label class="label" for="password">Contraseña</label>
          <input id="password" type="password" class="input" placeholder="Mínimo 8 caracteres" required minlength="8" />
          <p class="help">Mínimo 8 caracteres, al menos un número.</p>
        </div>
        <div>
          <label class="label" for="fecha">Fecha de nacimiento</label>
          <input id="fecha" type="date" class="input" required />
          <p class="help">Necesitamos saber tu edad para mostrarte cursos apropiados.</p>
        </div>
        <label class="flex items-start gap-2 text-sm">
          <input type="checkbox" required class="mt-1" />
          <span>Acepto los <a href="/terminos" target="_blank" class="text-[var(--color-primary)] underline">Términos y Condiciones</a> y el <a href="/privacidad" target="_blank" class="text-[var(--color-primary)] underline">Aviso de Privacidad</a>.</span>
        </label>
        <button type="submit" class="btn btn-primary btn-block">Crear mi cuenta</button>
      </form>
    </div>
  </div>
</PublicLayout>
