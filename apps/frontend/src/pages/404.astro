---
import PublicLayout from "@/layouts/PublicLayout.astro";
---
<PublicLayout title="Página no encontrada">
  <div class="min-h-screen grid place-items-center px-4">
    <div class="card p-10 text-center max-w-md">
      <p class="text-6xl mb-3">🧭</p>
      <h1 class="text-2xl font-bold">No encontramos esa página</h1>
      <p class="text-[var(--color-text-muted)] mt-2">Puede que se haya movido o que el enlace esté incorrecto.</p>
      <a href="/catalogo" class="btn btn-primary mt-6 inline-flex">Ir al catálogo</a>
    </div>
  </div>
</PublicLayout>
